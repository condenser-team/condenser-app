{
  "name": "condenser",
  "version": "1.0.0",
  "type": "module",
  "description": "Turns Steam into liquid",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:frontend && npm run build:plugins && npm run build:backend",
    "build:frontend": "NODE_ENV=production vite build --config frontend/vite.config.ts",
    "build:backend": "esbuild backend/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/bundle.cjs --external:bufferutil --external:utf-8-validate --external:fsevents",
    "build:plugins": "node scripts/build-plugins.mjs",
    "build:binaries": "npm run build && node scripts/pkg.mjs",
    "build:installer": "node scripts/installer.mjs",
    "build:release": "npm run build:binaries && npm run build:installer",
    "dev": "NODE_ENV=development concurrently \"vite --config frontend/vite.config.ts -- --mode local\" \"tsx watch backend/index.ts local\"",
    "dev:remote": "NODE_ENV=development concurrently \"vite --config frontend/vite.config.ts -- --mode remote\" \"tsx watch backend/index.ts remote\"",
    "stop": "tsx scripts/service.ts stop",
    "service:start": "tsx scripts/service.ts start",
    "service:stop": "tsx scripts/service.ts stop",
    "service:restart": "tsx scripts/service.ts restart",
    "service:status": "tsx scripts/service.ts status",
    "logs": "tsx scripts/service.ts logs",
    "app": "tsx scripts/app.ts game",
    "app:browser": "tsx watch scripts/browser.ts",
    "app:desktop": "tsx scripts/app.ts desktop",
    "debug": "tsx scripts/debug.ts",
    "dev:tools": "tsx scripts/devtools.ts",
    "setup": "tsx scripts/trust.ts local && tsx scripts/certs.ts local",
    "setup:remote": "tsx scripts/trust.ts local && tsx scripts/certs.ts remote && tsx scripts/trust.ts deck remote",
    "test": "playwright test"
  },
  "pkg": {
    "ignore": [
      "node_modules/bufferutil",
      "node_modules/utf-8-validate",
      "node_modules/fsevents"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@yao-pkg/pkg": "^5.12.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.28.0",
    "puppeteer": "^24.42.0",
    "react-devtools": "^7.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.10"
  },
  "keywords": [
    "condenser",
    "steam",
    "plugins"
  ],
  "author": "kmturley",
  "license": "MIT",
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "ws": "^8.18.3"
  }
}
