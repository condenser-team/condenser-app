{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "condenser:api": ["./library/api.ts"]
    }
  },
  "include": ["index.ts", "library/**/*.ts", "../shared/**/*.ts", "../plugins/**/*.tsx", "../plugins/**/*.ts"]
}