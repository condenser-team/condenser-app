#!/bin/bash
set -e

SCRIPT="/usr/local/share/condenser/uninstall.sh"

if [ ! -f "$SCRIPT" ]; then
  osascript -e 'display dialog "Condenser does not appear to be installed." buttons {"OK"} default button "OK" with title "Condenser (uninstall)" with icon stop'
  exit 1
fi

# Confirmation dialog
button=$(osascript <<'APPLESCRIPT'
  set answer to button returned of (display dialog "Are you sure you want to uninstall Condenser?" & return & return & "This will stop the service and remove all Condenser files." buttons {"Cancel", "Uninstall"} default button "Cancel" with title "Condenser (uninstall)" with icon caution)
  return answer
APPLESCRIPT
)

[ "$button" = "Uninstall" ] || exit 0

# Run uninstall script with admin privileges (prompts for macOS password)
osascript -e "do shell script \"$SCRIPT\" with administrator privileges"

osascript -e 'display dialog "Condenser has been uninstalled." buttons {"OK"} default button "OK" with title "Condenser (uninstall)"'
