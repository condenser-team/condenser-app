#!/bin/bash
# Install and activate the Condenser LaunchAgent for the currently logged-in user.
set -e

INSTALL_DIR="/usr/local/share/condenser"
BINARY="$INSTALL_DIR/condenser"
PLIST_SRC="$INSTALL_DIR/com.condenser.plist"
LOGGED_IN_USER=$(stat -f "%Su" /dev/console 2>/dev/null || echo "$USER")
LAUNCH_AGENTS_DIR="/Users/$LOGGED_IN_USER/Library/LaunchAgents"

chmod +x "$BINARY"
chown -R "$LOGGED_IN_USER" "$INSTALL_DIR"
mkdir -p "$LAUNCH_AGENTS_DIR"
cp "$PLIST_SRC" "$LAUNCH_AGENTS_DIR/com.condenser.plist"

# Load the agent as the logged-in user (ignore errors if already loaded)
sudo -u "$LOGGED_IN_USER" launchctl load -w "$LAUNCH_AGENTS_DIR/com.condenser.plist" 2>/dev/null || true

echo "Condenser service installed and started."
echo "Logs: $INSTALL_DIR/condenser.log"
echo "To uninstall: /usr/local/share/condenser/uninstall.sh"
